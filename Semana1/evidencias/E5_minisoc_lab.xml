<!-- MiniSOC Laboratorio - Reglas de detección -->
<!-- Autor: Karol Melissa Chacon Sanchez | Fecha: Abril 2026 -->

<group name="minisoc_lab,">

  <!-- R001: SSH Brute Force | MITRE ATT&CK T1110 -->
  <rule id="100001" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <description>R001 - Multiple SSH login failures - Brute force detected</description>
    <mitre><id>T1110</id></mitre>
    <group>authentication_failures,</group>
  </rule>

  <!-- R002: New user account created | MITRE ATT&CK T1136 -->
  <rule id="100002" level="8">
    <if_sid>5901</if_sid>
    <description>R002 - New user account created - Possible persistence</description>
    <mitre><id>T1136</id></mitre>
    <group>account_changes,</group>
  </rule>

  <!-- R003: Sudo privilege escalation | MITRE ATT&CK T1548 -->
  <rule id="100003" level="8">
    <if_sid>5402</if_sid>
    <description>R003 - Sudo privilege escalation attempt detected</description>
    <mitre><id>T1548</id></mitre>
    <group>privilege_escalation,</group>
  </rule>

  <!-- R004: Exfiltration via AI Inference API | MITRE ATLAS AML.T0024 -->
  <rule id="100004" level="10">
    <if_sid>1002</if_sid>
    <match>inference|api|model|predict</match>
    <description>R004 - Exfiltration via AI Inference API</description>
    <mitre><id>AML.T0024</id></mitre>
    <group>exfiltration,ai_attack,</group>
  </rule>

  <!-- R005: LLM Data Leakage | MITRE ATLAS AML.T0057 -->
  <rule id="100005" level="10">
    <if_sid>31106</if_sid>
    <match>prompt|llm|training_data|system_prompt</match>
    <description>R005 - LLM Data Leakage</description>
    <mitre><id>AML.T0057</id></mitre>
    <group>exfiltration,ai_attack,</group>
  </rule>

  <!-- R006: Craft Adversarial Data | MITRE ATLAS AML.T0043 -->
  <rule id="100006" level="10">
    <if_sid>1002</if_sid>
    <match>adversarial|poisoning|evasion|perturbation</match>
    <description>R006 - Craft Adversarial Data</description>
    <mitre><id>AML.T0043</id></mitre>
    <group>ai_attack,ml_attack_staging,</group>
  </rule>

  <!-- R007: Denial of AI Service | MITRE ATLAS AML.T0029 -->
  <rule id="100007" level="12">
    <if_sid>1002</if_sid>
    <match>overload|flood|model_timeout|inference_error</match>
    <description>R007 - Denial of AI Service</description>
    <mitre><id>AML.T0029</id></mitre>
    <group>ai_attack,denial_of_service,</group>
  </rule>

  <!-- R008: File integrity violation | MITRE ATT&CK T1565 -->
  <rule id="100008" level="12">
    <if_sid>550</if_sid>
    <field name="file">/etc/passwd</field>
    <description>R008 - File integrity violation - /etc/passwd modified</description>
    <mitre><id>T1565</id></mitre>
    <group>fim,</group>
  </rule>

  <!-- R009: Windows multiple login failures | MITRE ATT&CK T1110 -->
  <rule id="100009" level="10" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <description>R009 - Windows multiple login failures - Possible RDP brute force</description>
    <mitre><id>T1110</id></mitre>
    <group>authentication_failures,</group>
  </rule>

  <!-- R010: Create Proxy AI Model | MITRE ATLAS AML.T0005 -->
  <rule id="100010" level="10">
    <if_sid>5500</if_sid>
    <match>proxy_model|model_copy|model_extraction|stolen_model</match>
    <description>R010 - Create Proxy AI Model</description>
    <mitre><id>AML.T0005</id></mitre>
    <group>ai_attack,ml_attack_staging,</group>
  </rule>

</group>